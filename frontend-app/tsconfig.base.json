{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2015",
    "module": "esnext",
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@smwine-fe-app/admin": ["libs/admin/src/index.ts"],
      "@smwine-fe-app/interceptor": ["libs/interceptor/src/index.ts"],
      "@smwine-fe-app/security": ["libs/security/src/index.ts"],
      "@smwine-fe-app/store": ["libs/shared/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
